ENVIRONMENT=local
LOG_LEVEL=Information

# SHUTDOWN
SHUTDOWN_TIMEOUT_SECONDS=30
JOB_EXECUTION_TIMEOUT_SECONDS=300

# DATABASE (SQL Server)
DATABASE_URL="Server=localhost,1433;Database=backend_c_sharp;User Id=sa;Password=YourPassword123;TrustServerCertificate=True;"
DATABASE_COMMAND_TIMEOUT_SECONDS=10

# CACHE (Redis)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_COMMAND_TIMEOUT_SECONDS=5

# MESSAGING (RabbitMQ)
MESSAGING_ENABLED=false
RABBIT_URL=amqp://guest:guest@localhost:5672/
RABBIT_USER=guest
RABBIT_PASSWORD=guest
RABBITMQ_PUBLISH_TIMEOUT=5

# HEALTH CHECK
HEALTH_CHECK_CRON=*/1 * * * *
HEALTH_CHECK_ENABLED=true
