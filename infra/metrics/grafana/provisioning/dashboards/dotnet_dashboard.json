{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Total de Requisições (RPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_received_total[1m])) by (method, endpoint)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Latência Média (Segundos)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_sum[1m]) / rate(http_request_duration_seconds_count[1m])",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requisições por Status Code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_received_total[$__rate_interval])) by (code)",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "fillOpacity": 80,
            "pointSize": 5
          }
        }
      }
    },
    {
      "title": "Uso de Memória (RSS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS",
          "refId": "A"
        },
        {
          "expr": "dotnet_total_memory_bytes",
          "legendFormat": "Total GC Alloc",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Uso de CPU",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total[1m])",
          "legendFormat": "Total CPU Usage",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "GC Collections (Por Minuto)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rate(dotnet_gc_collection_count_total[1m]) * 60",
          "legendFormat": "Gen {{generation}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Thread Pool (Tarefas na Fila)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "targets": [
        {
          "expr": "system_runtime_threadpool_queue_length",
          "legendFormat": "Tarefas Enfileiradas",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Threads Ativas",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "targets": [
        {
          "expr": "system_runtime_threadpool_thread_count",
          "legendFormat": "Threads do Processo",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Taxa de Exceções (Por Minuto)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "rate(dotnet_exceptions_total[1m]) * 60",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Queries no Banco (Por Minuto)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "rate(microsoft_entityframeworkcore_microsoft_entityframeworkcore_queries[1m]) * 60",
          "legendFormat": "Consultas EF Core",
          "refId": "A"
        }
      ]
    }
  ],
