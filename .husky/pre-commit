#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."
echo ""

# ============================================================
# 1. Check for // comments in staged .cs files (src/ only)
#    Allows /// (XML doc comments) and URLs (://)
# ============================================================
echo "📝 Checking for // comments in source files..."

COMMENT_ERRORS=""
STAGED_CS_FILES=$(git diff --cached --name-only --diff-filter=ACM -- 'src/**/*.cs' ':(exclude)src/Migrations/')

if [ -n "$STAGED_CS_FILES" ]; then
    for file in $STAGED_CS_FILES; do
        # Get only the staged content (what will be committed)
        MATCHES=$(git show ":$file" 2>/dev/null | grep -n '[^:/]//\|^//' | grep -v '^[0-9]*:\s*///' | grep -v '://' || true)
        if [ -n "$MATCHES" ]; then
            COMMENT_ERRORS="${COMMENT_ERRORS}\n  ❌ ${file}:\n${MATCHES}\n"
        fi
    done
fi

if [ -n "$COMMENT_ERRORS" ]; then
    echo "❌ Found // comments in source code. Use /// for documentation or remove:"
    printf "$COMMENT_ERRORS"
    echo ""
    echo "💡 Tip: Use /// XML doc comments or remove unnecessary comments."
    exit 1
fi
echo "  ✅ No // comments found"
echo ""

# ============================================================
# 2. Run dotnet format (auto-fix staged files)
# ============================================================
echo "🎨 Running dotnet format..."

dotnet format src/MageBackend.csproj --verbosity quiet 2>/dev/null
FORMAT_EXIT=$?

if [ $FORMAT_EXIT -ne 0 ]; then
    echo "  ❌ dotnet format failed"
    exit 1
fi

# Re-stage any files that were modified by the formatter
FORMATTED_FILES=$(git diff --name-only -- 'src/**/*.cs')
if [ -n "$FORMATTED_FILES" ]; then
    echo "$FORMATTED_FILES" | xargs git add
    echo "  ✅ Formatted and re-staged modified files"
else
    echo "  ✅ Code already formatted"
fi
echo ""

# ============================================================
# 3. Run tests with coverage and enforce thresholds
# ============================================================
echo "🧪 Running tests with coverage..."

COVERAGE_OUTPUT=$(dotnet test tests/MageBackend.Tests.csproj -m:1 /p:CollectCoverage=true --verbosity quiet 2>&1)
TEST_EXIT=$?

if [ $TEST_EXIT -ne 0 ]; then
    echo "  ❌ Tests failed!"
    echo "$COVERAGE_OUTPUT" | tail -20
    exit 1
fi

echo "  ✅ All tests passed"
echo ""

# Parse coverage values from coverlet output
LINE_COV=$(echo "$COVERAGE_OUTPUT" | grep -A2 "| Total" | grep "Total" | awk -F'|' '{gsub(/[ %]/, "", $3); print $3}')
BRANCH_COV=$(echo "$COVERAGE_OUTPUT" | grep -A2 "| Total" | grep "Total" | awk -F'|' '{gsub(/[ %]/, "", $4); print $4}')
METHOD_COV=$(echo "$COVERAGE_OUTPUT" | grep -A2 "| Total" | grep "Total" | awk -F'|' '{gsub(/[ %]/, "", $5); print $5}')

# Thresholds
MIN_LINE=95
MIN_BRANCH=85
MIN_METHOD=95

echo "📊 Coverage thresholds:"
echo "  Line:   ${LINE_COV}% (min: ${MIN_LINE}%)"
echo "  Branch: ${BRANCH_COV}% (min: ${MIN_BRANCH}%)"
echo "  Method: ${METHOD_COV}% (min: ${MIN_METHOD}%)"
echo ""

FAILED=0

check_threshold() {
    local name=$1
    local actual=$2
    local min=$3

    if [ -z "$actual" ]; then
        echo "  ❌ Could not parse ${name} coverage"
        FAILED=1
        return
    fi

    # Compare using awk for float support
    PASS=$(awk "BEGIN { print ($actual >= $min) ? 1 : 0 }")
    if [ "$PASS" -eq 0 ]; then
        echo "  ❌ ${name} coverage ${actual}% is below minimum ${min}%"
        FAILED=1
    fi
}

check_threshold "Line" "$LINE_COV" "$MIN_LINE"
check_threshold "Branch" "$BRANCH_COV" "$MIN_BRANCH"
check_threshold "Method" "$METHOD_COV" "$MIN_METHOD"

if [ $FAILED -ne 0 ]; then
    echo ""
    echo "❌ Coverage thresholds not met. Commit blocked."
    exit 1
fi

echo ""
echo "✅ All pre-commit checks passed!"
